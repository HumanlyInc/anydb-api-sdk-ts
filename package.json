{
  "name": "anydb-api-sdk-ts",
  "version": "1.0.2",
  "description": "TypeScript SDK for AnyDB API - Interact with AnyDB records, databases, teams, and files",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest --testPathIgnorePatterns=integration",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest --testPathPattern=integration",
    "test:all": "jest",
    "test:watch": "jest --watch --testPathIgnorePatterns=integration",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=integration",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "anydb",
    "sdk",
    "typescript",
    "api",
    "database",
    "records",
    "file-management"
  ],
  "author": "Humanly Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HumanlyInc/anydb-api-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/HumanlyInc/anydb-api-sdk-ts/issues"
  },
  "homepage": "https://github.com/HumanlyInc/anydb-api-sdk-ts#readme",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
